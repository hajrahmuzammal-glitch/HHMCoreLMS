root = true

[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
# Braces — always use them, even for one-line if statements
csharp_prefer_braces = true:warning

# var usage — use var when type is obvious from the right side
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members — allow but do not require
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = when_on_single_line:suggestion

# Null checking — prefer is null over == null
csharp_style_prefer_null_check_over_type_check = true:suggestion

# Namespace style — file-scoped (cleaner, less nesting)
csharp_style_namespace_declarations = file_scoped:warning

# Unused parameters — warn so dead code is visible
dotnet_code_quality_unused_parameters = all:warning

# this. qualifier — do not require it
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion

# Organize usings
dotnet_sort_system_directives_first = true

[*.json]
indent_size = 2

[*.yml]
indent_size = 2

[*.md]
trim_trailing_whitespace = false